# 🏛️ Configurações LicitaAI (Exemplo)
# Renomeie este arquivo para .env e preencha seus dados reais

# Telegram (Obrigatório para notificações)
TOKEN_TELEGRAM=SEU_TOKEN_DO_BOT_AQUI
CHAT_ID=SEU_CHAT_ID_AQUI

# IA (Obrigatório para Analista de Editais)
# Obtenha sua chave em https://openrouter.ai/
OPENROUTER_API_KEY=SUA_CHAVE_OPENROUTER_AQUI
